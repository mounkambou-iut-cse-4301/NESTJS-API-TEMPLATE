// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// prisma/schema.prisma
datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

/**
 * =========================
 * Auth & rôles
 * =========================
 */

model Utilisateur {
  id                 Int       @id @default(autoincrement())
  nom                String
  email              String    
  mot_de_passe       String
  telephone          String    
  date_naissance     DateTime?
  genre              Genre?
  type               TypeUtilisateur @default(CLIENT)
  /// Compte vérifié (email / validation admin)
  is_verified        Boolean   @default(false)
  photo_url          String?
  /// Compte bloqué (accès refusé)
  is_block           Boolean   @default(false)
  /// Nombre de tentatives de connexion échouées
  nombre_attempts    Int       @default(0)
  derniere_connexion DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  roles           UtilisateurRole[]
  adresses        Adresse[]
  documents       Document[]
  portfolios      Portfolio[]
  modelProposes   Model[]       @relation("prestatairePropose")
  institutModels  InstitutModel[]
  reservations    Reservation[] @relation("client")
  prestations     Reservation[] @relation("prestataire")
  propositions    Proposition[]
  transactions    Transaction[]
}

model Role {
  id    Int               @id @default(autoincrement())
  nom   String            @unique // SUPER_ADMIN | ADMIN | CLIENT | PROFESSIONEL | INSTITUT
  perms RolePermission[]
  users UtilisateurRole[]
}

model Permission {
  id    Int              @id @default(autoincrement())
  code  String           @unique
  roles RolePermission[]
}

model UtilisateurRole {
  utilisateurId Int
  roleId        Int
  user          Utilisateur @relation(fields: [utilisateurId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  role          Role        @relation(fields: [roleId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@id([utilisateurId, roleId])
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Setting {
  id                           Int            @id @default(1)
  commission_domicile          Float          @default(0)
  commission_domicile_type     TypeCommission @default(POURCENTAGE)
  commission_institut          Float          @default(0)
  commission_institut_type     TypeCommission @default(POURCENTAGE)
  created_at                   DateTime       @default(now())
  updated_at                   DateTime       @updatedAt
}

/**
 * =========================
 * Nouvelles tables pour Dezoumay
 * =========================
 */

enum Genre {
  F
  M
}

enum TypeUtilisateur {
  SUPERADMIN
  ADMIN
  CLIENT
  PROFESSIONEL
  INSTITUT
}

enum StatutModele {
  PENDING
  CONFIRM
}

enum StatutReservation {
  PROPOSE
  EN_ATTENTE_PAIEMENT
  EN_ATTENTE_PRESTATION
  CANCEL
  COMPLETED
}

enum StatutPaiement {
  PENDING
  CONFIRM
  CANCEL
}

enum ModePaiement {
  CARTE
  MOBILE_MONEY
  ESPECES
}

enum TypeReservation {
  A_DOMICILE
  A_INSTITUT
}

enum TypeCommission {
  POURCENTAGE
  FIXE
}

model Adresse {
  id            Int         @id @default(autoincrement())
  country       String
  city          String
  address       String
  longitude     Float?
  latitude      Float?
  utilisateurId Int
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  reservations  Reservation[]

  @@map("adresses")
}

model Document {
  id            Int         @id @default(autoincrement())
  nom           String?
  images        String[]
  utilisateurId Int
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("documents")
}

model Categorie {
  id       Int       @id @default(autoincrement())
  nom      String    @unique
  image    String?
  services Service[]

  @@map("categories")
}

model Service {
  id          Int       @id @default(autoincrement())
  nom         String    @unique
  image       String?
  categorieId Int
  categorie   Categorie @relation(fields: [categorieId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  modeles     Model[]

  @@map("services")
}

model Model {
  id                    Int              @id @default(autoincrement())
  nom                   String
  images                String[]
  statut                StatutModele     @default(PENDING)
  prestataireProposeId  Int?
  serviceId             Int
  prestatairePropose    Utilisateur?     @relation("prestatairePropose", fields: [prestataireProposeId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  service               Service          @relation(fields: [serviceId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  tarifs                Tarif[]
  institutModels        InstitutModel[]
  portfolios            Portfolio[]
  reservations          Reservation[]

  @@map("modeles")
}

model Tarif {
  id           Int    @id @default(autoincrement())
  prix         Float
  duree_estime Int
  age_min      Int
  age_max      Int
  modelId      Int
  model        Model  @relation(fields: [modelId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("tarifs")
}

model InstitutModel {
  id            Int         @id @default(autoincrement())
  utilisateurId Int
  modelId       Int
  prix          Float
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  model         Model       @relation(fields: [modelId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@unique([utilisateurId, modelId])
  @@map("institut_modeles")
}

model Portfolio {
  id            Int         @id @default(autoincrement())
  images        String[]
  utilisateurId Int
  modelId       Int?
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  model         Model?      @relation(fields: [modelId], references: [id], onUpdate: Cascade, onDelete: SetNull)

  @@map("portfolios")
}

model Reservation {
  id                Int               @id @default(autoincrement())
  heure_debut       DateTime
  heure_fin         DateTime
  date_reservation  DateTime
  type              TypeReservation   @default(A_DOMICILE)
  statut            StatutReservation @default(PROPOSE)
  age               Int?
  sexe              Genre?
  nom_client        String
  numero_client     String
  clientId          Int
  modelId           Int
  adresseId         Int
  prestataireId     Int?
  client            Utilisateur       @relation("client", fields: [clientId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  model             Model             @relation(fields: [modelId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  adresse           Adresse           @relation(fields: [adresseId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  prestataire       Utilisateur?      @relation("prestataire", fields: [prestataireId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  propositions      Proposition[]
  transactions      Transaction[]

  @@map("reservations")
}

model Proposition {
  id            Int         @id @default(autoincrement())
  prestataireId Int
  reservationId Int
  prestataire   Utilisateur @relation(fields: [prestataireId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  reservation   Reservation @relation(fields: [reservationId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@unique([prestataireId, reservationId])
  @@map("propositions")
}

model Transaction {
  id               Int            @id @default(autoincrement())
  montant          Float
  date_paiement    DateTime?
  mode_paiement    ModePaiement?
  statut_paiement  StatutPaiement @default(PENDING)
  reservationId    Int?
  reservation      Reservation?   @relation(fields: [reservationId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  utilisateurId    Int
  utilisateur      Utilisateur    @relation(fields: [utilisateurId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@map("transactions")
}