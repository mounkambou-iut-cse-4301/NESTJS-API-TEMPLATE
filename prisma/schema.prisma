// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

/* =========================
   Territoire
   ========================= */

model Region {
  id              Int               @id @default(autoincrement())
  nom             String
  nom_en          String?
  code            String?           @unique
  departements    Departement[]
  communes        Commune[]
  infrastructures Infrastructure[]
}

model Departement {
  id               Int               @id @default(autoincrement())
  regionId         Int
  nom              String
  nom_en           String?
  code             String?           @unique

  region           Region            @relation(fields: [regionId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  arrondissements  Arrondissement[]
  communes         Commune[]
  infrastructures  Infrastructure[]
}

model Arrondissement {
  id               Int               @id @default(autoincrement())
  departementId    Int
  nom              String
  nom_en           String?
  code             String?           @unique

  departement      Departement       @relation(fields: [departementId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  communes         Commune[]
  infrastructures  Infrastructure[]
}

model Commune {
  id               Int               @id @default(autoincrement())
  arrondissementId Int?
  departementId    Int
  regionId         Int
  nom              String
  nom_en           String?
  nom_maire        String?
  longitude        Float?
  latitude         Float?
  code             String?           @unique
  typeCommuneId    Int?

  /// Commune vérifiée ?
  is_verified      Boolean           @default(true)
  /// Commune bloquée ?
  is_block         Boolean           @default(false)

  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  arrondissement   Arrondissement?   @relation(fields: [arrondissementId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  departement      Departement       @relation(fields: [departementId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  region           Region            @relation(fields: [regionId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  typeCommune      TypeCommune?      @relation(fields: [typeCommuneId], references: [id], onUpdate: Cascade, onDelete: SetNull)

  utilisateurs     Utilisateur[]
  infrastructures  Infrastructure[]
}

/* =========================
   Auth & rôles
   ========================= */

model Utilisateur {
  id                  Int               @id @default(autoincrement())
  nom                 String
  email               String            @unique
  mot_de_passe        String
  communeId           Int?
  telephone           String            @unique
  /// Compte vérifié (email / validation admin)
  is_verified         Boolean           @default(false)
  photo_url           String?
  ville               String?
  adresse             String?
  /// Compte bloqué (accès refusé)
  is_block            Boolean           @default(false)
  derniere_connexion  DateTime?
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt

  commune             Commune?          @relation(fields: [communeId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  roles               UtilisateurRole[]
  infrastructures     Infrastructure[]

  Parcour             Parcour[]
}

model Role {
  id     Int               @id @default(autoincrement())
  nom    String            @unique   // SUPER_ADMIN | MINISTERE | COMMUNE
  perms  RolePermission[]
  users  UtilisateurRole[]
}

model Permission {
  id     Int               @id @default(autoincrement())
  code   String            @unique   // MODELES_GERER, INFRA_ECRIRE, ...
  roles  RolePermission[]
}

model UtilisateurRole {
  utilisateurId Int
  roleId        Int
  user          Utilisateur  @relation(fields: [utilisateurId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  role          Role         @relation(fields: [roleId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@id([utilisateurId, roleId])
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role        @relation(fields: [roleId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Domaine {
  id               Int                 @id @default(autoincrement())
  nom              String              @unique
  nom_en           String?
  code             String?
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt

  sousDomaines     SousDomaine[]
  types            TypeInfrastructure[]
  infrastructures  Infrastructure[]
}

model SousDomaine {
  id               Int                 @id @default(autoincrement())
  domaineId        Int
  domaine          Domaine             @relation(fields: [domaineId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  nom              String
  nom_en          String?
  code            String?
  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt

  types           TypeInfrastructure[]
  infrastructures Infrastructure[]

  Competence      Competence[]
}

/// Points collectés sur le terrain (trace GPS)
model Parcour {
  id           BigInt        @id @default(autoincrement())
  collecteurId Int?
  collecteur   Utilisateur?  @relation(fields: [collecteurId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  latitude     Float
  longitude    Float
  recordedAt   DateTime

  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  @@index([collecteurId], name: "idx_parcour_collecteur")
  @@index([recordedAt],  name: "idx_parcour_recordedAt")
}

/// Typologie administrative d’une commune (ex: URBAINE / RURALE)
model TypeCommune {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  Commune    Commune[]
}

/// Référentiel de compétences (ex: SANTÉ, ÉDUCATION…)
model Competence {
  id             Int                 @id @default(autoincrement())
  name           String              @unique
  sousDomaineId  Int?
  sousDomaine    SousDomaine?        @relation(fields: [sousDomaineId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt

  Infrastructure      Infrastructure[]
  TypeInfrastructure  TypeInfrastructure[]
}

/* =========================
   Types d'infrastructure (modèles)
   ========================= */

model TypeInfrastructure {
  id           Int        @id @default(autoincrement())
  /// Nom du type (ex: "hopital")
  name         String     @unique
  /// Nature du type: "simple" ou "complexe"
  type         String
  /// Localisation par défaut (JSON libre)
  location     Json?
  /// Description textuelle du type
  description  String?
  /// Images par défaut (JSON libre)
  images       Json?
  /// Déclaration des attributs (JSON array)
  attribus     Json
  /// Déclaration des composants (JSON array) (récursif)
  composant    Json?

  /// Classification
  domaineId     Int?
  sousdomaineId Int?
  competenceId  Int?
  domaine       Domaine?       @relation(fields: [domaineId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  sousdomaine   SousDomaine?   @relation(fields: [sousdomaineId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  competence    Competence?    @relation(fields: [competenceId], references: [id], onUpdate: Cascade, onDelete: SetNull)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  infrastructures Infrastructure[]
}

/* =========================
   Infrastructures réelles (records)
   ========================= */

model Infrastructure {
  id                      BigInt   @id @default(autoincrement())

  id_parent               BigInt?
  parent                  Infrastructure?  @relation("InfrastructureParent", fields: [id_parent], references: [id], onUpdate: Cascade, onDelete: Cascade)
  children                Infrastructure[] @relation("InfrastructureParent")

  /// Référence du type (modèle)
  id_type_infrastructure  Int
  typeRef                 TypeInfrastructure @relation(fields: [id_type_infrastructure], references: [id], onUpdate: Cascade, onDelete: Restrict)

  /// Nom lisible (ex: "Hopital de djongolo")
  name                    String
  /// Description textuelle du record communal
  description             String?

  /// Infrastructure déjà existante ? (1/0)
  existing_infrastructure Boolean  @default(true)

  /// "simple" | "complexe"
  type                    String

  /* Liens territoriaux (FK) */
  regionId         Int
  departementId    Int
  arrondissementId Int
  communeId        Int
  utilisateurId    Int?
  competenceId     Int?

  region           Region         @relation(fields: [regionId],         references: [id], onUpdate: Cascade, onDelete: Restrict)
  departement      Departement    @relation(fields: [departementId],    references: [id], onUpdate: Cascade, onDelete: Restrict)
  arrondissement   Arrondissement @relation(fields: [arrondissementId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  commune          Commune        @relation(fields: [communeId],        references: [id], onUpdate: Cascade, onDelete: Restrict)
  utilisateur      Utilisateur?   @relation(fields: [utilisateurId],    references: [id], onUpdate: Cascade, onDelete: SetNull)
  competence       Competence?    @relation(fields: [competenceId],     references: [id], onUpdate: Cascade, onDelete: SetNull)

  /// Localisation réelle (JSON libre)
  location    Json?
  /// Photos réelles (JSON libre)
  images      Json?
  /// Attributs réels (JSON objet)
  attribus    Json

  /// Classification
  domaineId     Int?
  sousdomaineId Int?
  domaine       Domaine?      @relation(fields: [domaineId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  sousdomaine   SousDomaine?  @relation(fields: [sousdomaineId], references: [id], onUpdate: Cascade, onDelete: SetNull)

  /// Composants réels (JSON array)
  composant   Json?

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([communeId], name: "idx_infra_commune")
  @@index([id_type_infrastructure], name: "idx_infra_type")
}

model DeletedInfrastructure {
  /// On conserve le même id que l’infrastructure d’origine
  id                      BigInt   @id
  id_parent               BigInt?
  id_type_infrastructure  Int
  name                    String
  description             String?
  existing_infrastructure Boolean  @default(true)
  type                    String
  regionId                Int
  departementId           Int
  arrondissementId        Int
  communeId               Int
  domaineId               Int?
  sousdomaineId           Int?
  competenceId            Int?
  utilisateurId           Int?
  location                Json?
  images                  Json?
  attribus                Json?
  composant               Json?
  created_at              DateTime
  updated_at              DateTime

  /// Colonnes additionnelles
  reason                  String
  fileURL                 String

  @@map("DeletedInfrastructure")
}
