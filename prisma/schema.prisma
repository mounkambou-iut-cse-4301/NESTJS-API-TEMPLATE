// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// prisma/schema.prisma
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
    shadowDatabaseUrl = env("SHADOW_DATABASE_URL")

}

/* =========================
   Territoire
   ========================= */

model Region {
  id             Int             @id @default(autoincrement())
  nom            String
  nom_en        String?
  code           String?         @unique
  departements   Departement[]   // back-rel sur Departement.region
  communes       Commune[]       // back-rel sur Commune.region
  infrastructures Infrastructure[] // back-rel sur Infrastructure.region
}

model Departement {
  id             Int             @id @default(autoincrement())
  regionId       Int
  nom            String
  nom_en        String?
  code           String?         @unique

  region         Region          @relation(fields: [regionId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  arrondissements Arrondissement[] // back-rel sur Arrondissement.departement
  communes       Commune[]         // back-rel sur Commune.departement
  infrastructures Infrastructure[] // back-rel sur Infrastructure.departement
}

model Arrondissement {
  id            Int             @id @default(autoincrement())
  departementId Int
  nom           String
  nom_en        String?
  code          String?         @unique

  departement   Departement     @relation(fields: [departementId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  communes      Commune[]       // back-rel sur Commune.arrondissement
  infrastructures Infrastructure[] // back-rel sur Infrastructure.arrondissement
}

model Commune {
  id               Int             @id @default(autoincrement())
  arrondissementId Int
  departementId    Int
  regionId         Int
  nom              String
  nom_en           String?
  longitude        Float?
  latitude         Float?
  code             String?         @unique

  /// Commune vérifiée ?
  is_verified      Boolean         @default(false)
  /// Commune bloquée ?
  is_block         Boolean         @default(false)

  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt

  arrondissement   Arrondissement  @relation(fields: [arrondissementId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  departement      Departement     @relation(fields: [departementId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  region           Region          @relation(fields: [regionId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  utilisateurs     Utilisateur[]   // back-rel sur Utilisateur.commune
  infrastructures  Infrastructure[] // back-rel sur Infrastructure.commune
}

/* =========================
   Auth & rôles
   ========================= */

model Utilisateur {
  id                 Int        @id @default(autoincrement())
  nom                String
  email              String     @unique
  mot_de_passe       String
  communeId          Int?
  telephone          String     @unique
  /// Compte vérifié (email / validation admin)
  is_verified        Boolean    @default(false)
  photo_url          String?    // URL Cloudinary
  ville              String?
  adresse            String?
  /// Compte bloqué (accès refusé)
  is_block           Boolean    @default(false)
  derniere_connexion DateTime?
  created_at         DateTime   @default(now())
  updated_at         DateTime   @updatedAt

  commune            Commune?   @relation(fields: [communeId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  roles              UtilisateurRole[]
  infrastructures   Infrastructure[] // back-rel sur Infrastructure.user
}

model Role {
  id    Int               @id @default(autoincrement())
  nom   String            @unique   // SUPER_ADMIN | MINISTERE | COMMUNE
  perms RolePermission[]
  users UtilisateurRole[]
}

model Permission {
  id    Int               @id @default(autoincrement())
  code  String            @unique   // MODELES_GERER, INFRA_ECRIRE, ...
  roles RolePermission[]
}

model UtilisateurRole {
  utilisateurId Int
  roleId        Int
  user          Utilisateur  @relation(fields: [utilisateurId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  role          Role         @relation(fields: [roleId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@id([utilisateurId, roleId])
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role        @relation(fields: [roleId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Domaine {
  id          Int              @id @default(autoincrement())
  nom         String           @unique
  nom_en      String?
  code        String?
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt

  sousDomaines     SousDomaine[]
  types            TypeInfrastructure[]
  infrastructures  Infrastructure[]
}

model SousDomaine {
  id          Int       @id @default(autoincrement())
  domaineId   Int
  domaine     Domaine   @relation(fields: [domaineId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  nom         String
  nom_en      String?
  code        String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  types            TypeInfrastructure[]
  infrastructures  Infrastructure[]
}

/* =========================
   Types d'infrastructure (modèles)
   ========================= */

model TypeInfrastructure {
  id        Int      @id @default(autoincrement())

  /// Nom du type (ex: "hopital")
  name      String   @unique

  /// Nature du type: "simple" ou "complexe"
  type      String

  /// Localisation par défaut (JSON libre)
  /// Exemple: { "lat": 0, "log": 0 }
  location  Json?

    /// Description textuelle du type
  description String?

  /// Images par défaut (JSON libre)
  /// Exemple: ["https://..."]
  images    Json?

  /// Déclaration des attributs (JSON array) décidés par le super-admin
  /// Exemple:
  /// [
  ///   {"key":"nombreBlocOperatoire","type":"number","value":null},
  ///   {"key":"NombrePharmacie","type":"number","value":null}
  /// ]
  attribus  Json

  /// Déclaration des composants (JSON array) décidés par le super-admin (récursif)
  /// Exemple:
  /// [
  ///   {
  ///     "id":1,"name":"Pharmacie","type":"simple",
  ///     "location":{"lat":0,"log":0},
  ///     "images":[""],
  ///     "attribus":[{"key":"nombreLit","type":"number","value":null}]
  ///   }
  /// ]
  composant Json?

  /// Classification
  domaineId      Int?
  sousdomaineId  Int?
  domaine        Domaine?      @relation(fields: [domaineId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  sousdomaine    SousDomaine?  @relation(fields: [sousdomaineId], references: [id], onUpdate: Cascade, onDelete: SetNull)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  infrastructures Infrastructure[]
}

/* =========================
   Infrastructures réelles (records)
   ========================= */

model Infrastructure {
  id                     BigInt   @id @default(autoincrement())

  /// Référence du type (modèle) — correspond à id dans TypeInfrastructure
  id_type_infrastructure Int
  typeRef                TypeInfrastructure @relation(fields: [id_type_infrastructure], references: [id], onUpdate: Cascade, onDelete: Restrict)

  /// Nom lisible (ex: "Hopital de djongolo")
  name                   String

    /// Description textuelle du record communal
  description String?

  /// Infrastructure déjà existante ? (1/0)
  existing_infrastructure Boolean  @default(true)

  /// "simple" | "complexe"
  type                   String

  /* Liens territoriaux (FK) */
  regionId        Int
  departementId   Int
  arrondissementId Int
  communeId       Int
  utilisateurId          Int?

  region         Region         @relation(fields: [regionId],        references: [id], onUpdate: Cascade, onDelete: Restrict)
  departement    Departement    @relation(fields: [departementId],   references: [id], onUpdate: Cascade, onDelete: Restrict)
  arrondissement Arrondissement @relation(fields: [arrondissementId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  commune        Commune        @relation(fields: [communeId],       references: [id], onUpdate: Cascade, onDelete: Restrict)
  utilisateur    Utilisateur?   @relation(fields: [utilisateurId],  references: [id], onUpdate: Cascade, onDelete: SetNull)

  /// Localisation réelle (JSON libre)
  /// Exemple: { "lat": 1111, "log": 212321 }
  location   Json?

  /// Photos réelles (JSON libre)
  /// Exemple: ["https://example.com/image.jpg"]
  images     Json?

  /// Attributs réels (JSON objet, clé → valeur)
  /// Exemple: { "NombrePharmacie": 1, "NombreChambre": 10 }
  attribus   Json

  /// Classification
  domaineId      Int?
  sousdomaineId  Int?
  domaine        Domaine?      @relation(fields: [domaineId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  sousdomaine    SousDomaine?  @relation(fields: [sousdomaineId], references: [id], onUpdate: Cascade, onDelete: SetNull)


  /// Composants réels (JSON array)
  /// Exemple:
  /// [
  ///   {
  ///     "id":1,"name":"Pharmacie","type":"simple","existingInfrastructure":true,
  ///     "location":{"lat":1223,"log":1232132},
  ///     "images":["https://example.com/image.jpg"],
  ///     "attribus":{"nombreLit":5,"nombreDeCiseau":10,"Hauteur":2.5,"largeur":3.0}
  ///   }
  /// ]
  composant  Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([communeId], name: "idx_infra_commune")
  @@index([id_type_infrastructure], name: "idx_infra_type")
}
